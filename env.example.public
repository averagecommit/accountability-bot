# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (100% FREE - get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Daily message limit per user (default: 30)
# Calculate: 1500 / DAILY_MESSAGE_LIMIT = max users per day
# Examples:
#   20 messages/user = 75 users/day
#   30 messages/user = 50 users/day
#   50 messages/user = 30 users/day
DAILY_MESSAGE_LIMIT=50

